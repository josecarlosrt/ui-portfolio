---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const inputClasses =
  'w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-base text-white placeholder:text-zinc-500 transition-colors focus-visible:outline-none focus-visible:border-white/40 focus-visible:ring-2 focus-visible:ring-white/20';
---

<Layout
  title="Contact — Jose Rivera | UX/UI Designer & Developer"
  description="Get in touch about projects, roles, or collaborations. I usually reply within 24 hours."
>
  <Header />
  <main class="relative z-10 min-h-screen px-6 md:px-12 pt-36 md:pt-44 pb-24">
    <div class="max-w-xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-medium tracking-tighter text-white mb-4">
        Let's talk.
      </h1>
      <p class="text-lg text-zinc-400 font-light leading-relaxed mb-12">
        Have a project in mind, a role to fill, or just want to say hi? I usually reply within 24 hours.
      </p>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        action="/contact/thanks"
        class="flex flex-col gap-6 [color-scheme:dark]"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden" style="display:none">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>

        <div class="flex flex-col gap-2">
          <label for="name" class="text-sm font-medium text-zinc-300">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            class={inputClasses}
          />
        </div>

        <div class="flex flex-col gap-2">
          <label for="email" class="text-sm font-medium text-zinc-300">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class={inputClasses}
          />
        </div>

        <div class="flex flex-col gap-2">
          <label for="topic" class="text-sm font-medium text-zinc-300">What's this about?</label>
          <div class="relative">
            <select id="topic" name="topic" class={`${inputClasses} appearance-none pr-10`}>
              <option>Project inquiry</option>
              <option>Job opportunity</option>
              <option>Something else</option>
            </select>
            <svg
              class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-zinc-400"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label for="message" class="text-sm font-medium text-zinc-300">Message</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            placeholder="Tell me a bit about your project or role..."
            class={`${inputClasses} resize-y`}></textarea>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto sm:self-start inline-flex items-center justify-center px-8 py-4 bg-white text-black font-medium rounded-full hover:bg-neutral-200 transition-colors duration-300 cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/40 focus-visible:ring-offset-2 focus-visible:ring-offset-[#0a0a0a]"
        >
          Send message
        </button>
      </form>

      <p class="mt-12 text-sm text-zinc-500">
        Prefer email?
        <a href="mailto:josecarlosrt7@gmail.com" class="text-zinc-400 hover:text-white transition-colors">josecarlosrt7@gmail.com</a>
        <span class="mx-2">·</span>
        <a
          href="https://www.linkedin.com/in/jose-carlos-rivera-670375197/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-zinc-400 hover:text-white transition-colors">LinkedIn</a
        >
      </p>
    </div>
  </main>
  <Footer />
</Layout>
