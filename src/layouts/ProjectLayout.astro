---
import "../styles/global.css";
import Layout from "./Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
const fm = Astro.props.frontmatter ?? Astro.props.content ?? {};
const { title, date, role, client, tools = [], images = [], summary } = fm;
---
<Layout>
<Header />
<main class="text-white min-h-screen pt-32 pb-12">
  <section class="mx-auto max-w-4xl px-6">
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-medium tracking-tighter leading-[1.1] mb-6">
      {title}
    </h1>
    <div class="mt-4 flex flex-col md:flex-row md:items-center gap-4 text-neutral-400 font-medium tracking-wide">
      <p>
        {date}{role && ` — ${role}`}{client && ` — ${client}`}
      </p>
      
      {tools.length > 0 && (
        <ul class="flex flex-wrap gap-2 md:ml-auto">
          {tools.map((t: unknown) => (
            <li class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs">{t}</li>
          ))}
        </ul>
      )}
    </div>

    {summary && (
      <p class="mt-12 text-lg md:text-xl font-light leading-relaxed text-neutral-300 max-w-3xl">
        {summary}
      </p>
    )}

    {images.length > 0 && (
      <div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
        {images.slice(0, 4).map((src: string) => (
          <img src={src} alt={title} class="aspect-[4/3] w-full rounded-2xl object-cover shadow-2xl border border-white/5" />
        ))}
      </div>
    )}

    <article class="prose prose-lg md:prose-xl prose-invert mt-16 max-w-none prose-headings:font-medium prose-headings:tracking-tight prose-headings:text-white prose-p:font-light prose-p:text-neutral-400 prose-a:text-white hover:prose-a:text-neutral-300">
      <slot />
    </article>
    
    <div class="mt-24 text-center md:text-left">
      <a
        href="/#work"
        class="inline-flex items-center justify-center px-8 py-4 bg-white text-black font-medium rounded-full hover:bg-neutral-200 transition-colors duration-300"
      >
         Back to Work
      </a>
    </div>
  </section>
</main>
<Footer />
</Layout>
